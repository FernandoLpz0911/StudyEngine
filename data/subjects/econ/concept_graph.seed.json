{
  "subject": "econ",
  "concepts": [
    {
      "id": "econ.incentives",
      "name": "Incentives",
      "category": "core",
      "exam_weight": 3,
      "card": {
        "question": "Freakonomics groups incentives into which three types?",
        "answer": "Economic, social, and moral",
        "distractors": [
          "Fixed, variable, and marginal",
          "Positive, negative, and neutral",
          "Short-run, long-run, and permanent"
        ]
      }
    },
    {
      "id": "econ.opportunity_cost",
      "name": "Opportunity Cost",
      "category": "core",
      "exam_weight": 3,
      "card": {
        "question": "The opportunity cost of a choice is:",
        "answer": "The value of the next-best alternative forgone",
        "distractors": [
          "The money price you pay",
          "The total value of all alternatives forgone",
          "The sunk cost already incurred"
        ]
      }
    },
    {
      "id": "econ.marginal",
      "name": "Thinking at the Margin",
      "category": "core",
      "exam_weight": 3,
      "prerequisites": ["econ.opportunity_cost"],
      "card": {
        "question": "Thinking at the margin means deciding based on:",
        "answer": "The benefit and cost of one more unit",
        "distractors": [
          "Total benefit versus total cost",
          "Average cost per unit",
          "The sunk cost already spent"
        ]
      }
    },
    {
      "id": "econ.correlation_causation",
      "name": "Correlation vs Causation",
      "category": "method",
      "exam_weight": 3,
      "card": {
        "question": "A spurious correlation between A and B is best explained by:",
        "answer": "A confounding variable that drives both",
        "distractors": [
          "A directly causing B",
          "B directly causing A",
          "A properly randomized experiment"
        ]
      }
    },
    {
      "id": "econ.moral_hazard",
      "name": "Moral Hazard",
      "category": "information",
      "exam_weight": 2,
      "prerequisites": ["econ.incentives"],
      "card": {
        "question": "Moral hazard arises from:",
        "answer": "Hidden action after a deal, when a party doesn't bear the full risk",
        "distractors": [
          "Hidden information before a deal",
          "Two parties having identical information",
          "A binding price ceiling"
        ]
      }
    },
    {
      "id": "econ.adverse_selection",
      "name": "Adverse Selection",
      "category": "information",
      "exam_weight": 2,
      "prerequisites": ["econ.incentives"],
      "card": {
        "question": "Adverse selection differs from moral hazard in that it involves:",
        "answer": "Hidden information before the deal (who chooses to participate)",
        "distractors": [
          "Hidden action after the deal",
          "Perfectly symmetric information",
          "Government price regulation"
        ]
      }
    },
    {
      "id": "econ.information_asymmetry",
      "name": "Information Asymmetry",
      "category": "information",
      "exam_weight": 3,
      "prerequisites": ["econ.moral_hazard"],
      "card": {
        "question": "Information asymmetry lets an expert (e.g. an agent):",
        "answer": "Exploit knowing more than the client to serve their own incentives",
        "distractors": [
          "Always act in the client's best interest",
          "Eliminate moral hazard entirely",
          "Guarantee an efficient market outcome"
        ]
      }
    },
    {
      "id": "econ.unintended_consequences",
      "name": "Unintended Consequences",
      "category": "core",
      "exam_weight": 2,
      "prerequisites": ["econ.incentives"],
      "card": {
        "question": "The daycare late-pickup fine increased lateness because it:",
        "answer": "Reframed a moral breach as a small price worth paying",
        "distractors": [
          "Was priced too high for parents to afford",
          "Eliminated the daycare's operating costs",
          "Made parents arrive earlier on average"
        ]
      }
    }
  ]
}
