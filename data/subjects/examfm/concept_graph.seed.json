    {
      "id": "fm.tvm_concept",
      "name": "Time Value of Money",
      "category": "interest_theory",
      "exam_weight": 2,
      "card": {
        "question": "The time value of money principle says that:",
        "answer": "a dollar today is worth more than a dollar later because it can earn interest",
        "distractors": [
          "a dollar later is worth more because of inflation",
          "money has the same value regardless of timing",
          "interest only matters for loans, not investments"
        ]
      }
    },
    {
      "id": "fm.nominal_effective",
      "name": "Nominal vs Effective Rates",
      "category": "interest_theory",
      "exam_weight": 3,
      "prerequisites": ["fm.tvm_concept"],
      "card": {
        "question": "How does a nominal annual rate i^(m) (compounded m times) relate to the effective annual rate i?",
        "answer": "i = (1 + i^(m)/m)^m − 1",
        "distractors": [
          "i = i^(m)/m",
          "i = i^(m) × m",
          "i = (1 + i^(m))^m − 1"
        ]
      }
    },
    {
