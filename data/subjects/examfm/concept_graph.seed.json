      "category": "annuities",
      "exam_weight": 2,
      "prerequisites": ["fm.tvm_concept"],
      "card": {
        "question": "In an annuity-due (versus annuity-immediate), payments are made:",
        "answer": "at the beginning of each period",
        "distractors": [
          "at the end of each period",
          "only once, at the start",
          "at the midpoint of each period"
        ]
      }
